{
  "name": "record-all",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "serve:e2e": "npm run build && vite preview --host 127.0.0.1 --port 4174",
    "bridge": "tsx src/agent/bridge/main.ts",
