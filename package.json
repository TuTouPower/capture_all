    "test:e2e:server": "npx tsx tests/fixtures/server.ts"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "fake-indexeddb": "^6.2.5",
    "playwright": "^1.60.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fflate": "^0.8.3",
    "zod": "^4.4.3"
  }
