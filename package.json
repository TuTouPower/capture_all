{
  "name": "capture-all",
  "private": true,
  "version": "0.1.0",
  "description": "Chrome MV3 browser debugging extension for structured capture, export, and AI agent querying",
  "keywords": [
    "chrome-extension",
    "browser-debugging",
    "browser-automation",
    "mcp",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TuTouPower/capture_all.git"
  },
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && npm run build:bridge && npm run build:mcp",
    "test": "vitest run",
    "test:watch": "vitest",
    "scan:tracked-tree": "node scripts/scan_tracked_tree.mjs",
    "serve:e2e": "npm run build && vite preview --host 127.0.0.1 --port 4174",
    "bridge": "tsx src/agent/bridge/main.ts",
    "mcp": "tsx src/agent/mcp/main.ts",
    "test:e2e": "playwright test --project=e2e",
    "test:e2e:all": "playwright test",
    "test:e2e:server": "npx tsx tests/fixtures/server.ts",
    "build:bridge": "esbuild src/agent/bridge/main.ts --bundle --platform=node --format=esm --external:ws --outfile=artifacts/bridge/bridge.mjs",
    "build:mcp": "esbuild src/agent/mcp/main.ts --bundle --platform=node --format=esm --external:ws --outfile=artifacts/mcp/mcp.mjs"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fflate": "^0.8.3",
    "zod": "^4.4.3"
  }
}
